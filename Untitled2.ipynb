      "source": [
        "import requests\n",
        "from PIL import Image\n",
        "from io import BytesIO\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "url = \"https://picsum.photos/400\"\n",
        "\n",
        "response = requests.get(url)\n",
        "\n",
        "img = Image.open(BytesIO(response.content))\n",
        "\n",
        "plt.imshow(img)\n",
        "plt.axis('off')"
      ]
    }
